# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA envie o arquivo .env para o GitHub

# Cole aqui a connection string do Supabase
# Encontre em: Supabase > Project > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Chave secreta do Flask (gere uma aleatória: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# Em produção deixe como 0
FLASK_DEBUG=0
